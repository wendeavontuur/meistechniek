---
import {sanity} from '../../lib/sanity'
import {siteSettingsQuery} from '../../lib/queries'
import type {SiteSettings} from '../../lib/types'

interface Props {
  subtitle?: string
  title?: string
  text?: string
  hashurl?: string
}
const {subtitle, title, text, hashurl} = Astro.props
const anchor = hashurl ? hashurl.toLowerCase().replace(/\s+/g, '-') : undefined

const settings = await sanity.fetch<SiteSettings | null>(siteSettingsQuery)
const formAction = settings?.formspreeEndpoint ?? 'https://formspree.io/f/xkgzaazv'
---

<div class="s-contactForm section-m" id={anchor}>
  <div class="s-contactForm__text">
    {subtitle && <p class="c-sectionLabel">{subtitle}</p>}
    {title && <h3 class="c-sectionTitle">{title}</h3>}
    {text && <p class="c-sectionText">{text}<br /></p>}
  </div>
  <div class="s-contactForm__form">
    <form action={formAction} method="POST">
      <div class="form-row">
        <div class="form-group">
          <label for="name">Je naam *</label>
          <input type="text" id="name" name="name" required />
        </div>
        <div class="form-group">
          <label for="email">E-mail adres *</label>
          <input type="email" id="email" name="email" required />
        </div>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="phone">Telefoonnummer</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            pattern="^\+?[0-9\s\-]{7,15}$"
            title="Voer een geldig telefoonnummer in"
          />
        </div>
      </div>
      <div class="form-group">
        <label for="message">Je vraag of projectbeschrijving *</label>
        <textarea id="message" name="message" required></textarea>
      </div>
      <input class="btn btn-primary" type="submit" value="Connect" />
    </form>
  </div>
</div>
