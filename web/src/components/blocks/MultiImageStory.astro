---
import StoryText from './_StoryText.astro'
import {thumb} from '../../lib/image'
import type {PortableTextBlock} from '@portabletext/types'
import type {CtaValue, SanityImage} from '../../lib/types'

interface Props {
  subtitle?: string
  title?: string
  text?: PortableTextBlock[]
  cta?: CtaValue[]
  radio?: string
  hashurl?: string
  images?: SanityImage[]
}
const {subtitle, title, text, cta, radio = 'img-left', hashurl, images = []} = Astro.props
const anchor = hashurl ? hashurl.toLowerCase().replace(/\s+/g, '-') : undefined
const slides = images.map((img) => ({src: thumb(img, 1200, 900, true), alt: img.alt ?? ''}))
---

<div class={`s-storyBlock section-l sectionBlock ${radio}`} id={anchor}>
  <div class="s-storyBlock__text">
    <StoryText subtitle={subtitle} title={title} text={text} cta={cta} />
  </div>

  {
    slides.length > 0 && (
      <div class="s-storyBlock__image s-storyGallery" data-gallery>
        <div class="s-storyGallery__viewport">
          <div class="s-storyGallery__track">
            {slides.map((s) => (
              <div class="s-storyGallery__slide">
                <img draggable="false" src={s.src} alt={s.alt} loading="lazy" decoding="async" />
              </div>
            ))}
          </div>
        </div>
        <div class="s-storyGallery__nav">
          <span class="s-gallery-prev" aria-label="Vorige afbeelding"><img src="/assets/images/arrow-l.png" alt="" /></span>
          <span class="s-gallery-next" aria-label="Volgende afbeelding"><img src="/assets/images/arrow-r.png" alt="" /></span>
        </div>
      </div>
    )
  }
</div>

<script is:inline>
;(function () {
  function init(root) {
    const viewport = root.querySelector('.s-storyGallery__viewport')
    const track = root.querySelector('.s-storyGallery__track')
    const slides = Array.from(root.querySelectorAll('.s-storyGallery__slide'))
    const btnPrev = root.querySelector('.s-gallery-prev')
    const btnNext = root.querySelector('.s-gallery-next')
    if (!track || slides.length === 0) return

    let isDragging = false
    let startX = 0
    let scrollLeft = 0
    let currentSlide = 0
    let edgeTriggered = false
    const getSlideWidth = () => slides[0].offsetWidth

    function animateScrollTo(target) {
      const start = track.scrollLeft
      const distance = target - start
      const startTime = performance.now()
      function step(t) {
        const elapsed = t - startTime
        const p = Math.min(elapsed / 300, 1)
        const eased = p * (2 - p)
        track.scrollLeft = start + distance * eased
        if (p < 1) requestAnimationFrame(step)
      }
      requestAnimationFrame(step)
    }
    function snapToSlide(idx) {
      currentSlide = Math.max(0, Math.min(idx, slides.length - 1))
      animateScrollTo(getSlideWidth() * currentSlide)
    }
    function startDrag(e) {
      isDragging = true
      edgeTriggered = false
      startX = e.pageX || e.touches[0].pageX
      scrollLeft = track.scrollLeft
      track.classList.add('dragging')
    }
    function duringDrag(e) {
      if (!isDragging || edgeTriggered) return
      const x = e.pageX || e.touches[0].pageX
      const walk = startX - x
      track.scrollLeft = scrollLeft + walk
      const threshold = getSlideWidth() * 0.35
      if (walk > threshold) {
        edgeTriggered = true; isDragging = false; track.classList.remove('dragging')
        snapToSlide(currentSlide + 1); return
      } else if (walk < -threshold) {
        edgeTriggered = true; isDragging = false; track.classList.remove('dragging')
        snapToSlide(currentSlide - 1); return
      }
      const vr = viewport.getBoundingClientRect()
      const edge = vr.width * 0.02
      if (x < vr.left + edge) {
        edgeTriggered = true; isDragging = false; track.classList.remove('dragging')
        snapToSlide(currentSlide + 1)
      } else if (x > vr.right - edge) {
        edgeTriggered = true; isDragging = false; track.classList.remove('dragging')
        snapToSlide(currentSlide - 1)
      }
    }
    function endDrag() {
      if (!isDragging) return
      isDragging = false
      track.classList.remove('dragging')
      snapToSlide(currentSlide)
    }
    btnPrev?.addEventListener('click', () => snapToSlide(currentSlide - 1))
    btnNext?.addEventListener('click', () => snapToSlide(currentSlide + 1))
    track.addEventListener('mousedown', startDrag)
    track.addEventListener('mousemove', duringDrag)
    track.addEventListener('mouseup', endDrag)
    track.addEventListener('mouseleave', endDrag)
    track.addEventListener('touchstart', startDrag, {passive: true})
    track.addEventListener('touchmove', duringDrag, {passive: true})
    track.addEventListener('touchend', endDrag)
    slides.forEach((s) => {
      const img = s.querySelector('img')
      if (img) img.setAttribute('draggable', 'false')
    })
    window.addEventListener('resize', () => snapToSlide(currentSlide))
    snapToSlide(0)
  }
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('[data-gallery]').forEach(init)
  })
})()
</script>
