---
import StoryText from './_StoryText.astro'
import {thumb} from '../../lib/image'
import type {PortableTextBlock} from '@portabletext/types'
import type {CtaValue, SanityImage} from '../../lib/types'

interface Props {
  subtitle?: string
  title?: string
  text?: PortableTextBlock[]
  cta?: CtaValue[]
  radio?: string
  hashurl?: string
  images?: SanityImage[]
}
const {subtitle, title, text, cta, radio = 'img-left', hashurl, images = []} = Astro.props
const anchor = hashurl ? hashurl.toLowerCase().replace(/\s+/g, '-') : undefined
const [img1, img2, img3] = images
const src1 = img1 ? thumb(img1, 700, 900, true) : null
const src2 = img2 ? thumb(img2, 700, 900, true) : null
const src3 = img3 ? thumb(img3, 700, 500, true) : null
---

<div class={`s-storyBlockGallery section-l sectionBlock ${radio}`} id={anchor}>
  <div class="s-storyBlockGallery__images">
    <div class="s-storyBlockGallery__images__left">
      {src1 && <img src={src1} alt={img1.alt ?? ''} loading="lazy" decoding="async" />}
    </div>
    <div class="s-storyBlockGallery__images__right">
      {src2 && <img src={src2} alt={img2.alt ?? ''} loading="lazy" decoding="async" />}
      {src3 && <img src={src3} alt={img3.alt ?? ''} loading="lazy" decoding="async" />}
    </div>
    <div class="s-storyBlockGallery__images__overlay noselect">
      <img src="/assets/images/blits-overlay-line.svg" alt="" />
    </div>
  </div>
  <div class="s-storyBlockGallery__text">
    <StoryText subtitle={subtitle} title={title} text={text} cta={cta} />
  </div>
</div>
