---
import type {SiteSettings} from '../lib/types'
import {resolveLink} from '../lib/url'

interface Props {
  settings?: SiteSettings | null
}
const {settings} = Astro.props

const rawTags = settings?.projectTags ?? []
const tags = [...rawTags].sort((a, b) => a.localeCompare(b))
const tagSlug = (tag: string) => tag.toLowerCase().replace(/\s+/g, '')
const extraColumns = settings?.footerColumns ?? []
---

<footer class="footer">
  <div class="footer__container">
    <div class="footer__column footer__logo">
      <img src="/assets/images/MEIS-footerlogo.svg" alt="Logo" />
    </div>

    <div class="footer__icon">
      <img src="/assets/images/MEIS-icon-white.svg" alt="Logo" />
    </div>

    <div class="footer__column footer_pages">
      {
        tags.length > 0 && (
          <div class="col">
            <h4><a href="/aanbod">AANBOD</a></h4>
            <ul>
              {tags.map((tag) => (
                <li>
                  <a href={`/aanbod#${tagSlug(tag)}`}>{tag}</a>
                </li>
              ))}
            </ul>
          </div>
        )
      }

      {
        extraColumns.map((col) => (
          <div class="col">
            <h4>{col.heading}</h4>
            <ul>
              {(col.links ?? []).map((l) => (
                <li>
                  <a href={resolveLink(l.link)}>{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</footer>
